# Server Configuration
PORT=5000
NODE_ENV=development
SERVER_URL=http://localhost:5000

# Frontend URLs
MERCHANT_FRONTEND_URL=http://localhost:3001
SHOPPER_FRONTEND_URL=http://localhost:3002
DELIVERY_FRONTEND_URL=http://localhost:3003
ADMIN_FRONTEND_URL=http://localhost:3004

# JWT Configuration
JWT_ACCESS_SECRET=your_access_secret_key_change_in_production
JWT_REFRESH_SECRET=your_refresh_secret_key_change_in_production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Databases
# MongoDB (Merchants)
MONGO_URI=mongodb://localhost:27017/ecommerce_merchants
MONGO_USER=mongouser
MONGO_PASSWORD=mongopass

# PostgreSQL (Shoppers, Delivery, SuperAdmin, Shared)
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=postgres
PG_DATABASE_SHOPPERS=ecommerce_shoppers
PG_DATABASE_DELIVERY=ecommerce_delivery
PG_DATABASE_ADMIN=ecommerce_admin
PG_DATABASE_SHARED=ecommerce_shared

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# External Services
# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=ecommerce-uploads

# Stripe Payments
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Maps
GOOGLE_MAPS_API_KEY=

# SendGrid Email
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@ecommerce.com

# Twilio SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Firebase FCM
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info

# Platform Configuration
PLATFORM_NAME=ECommerce Platform
PLATFORM_COMMISSION_PERCENT=10
PAYMENT_PROCESSING_FEE_PERCENT=2.9
